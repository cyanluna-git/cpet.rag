# ── cpet.rag 환경변수 (cp .env.example .env 후 채우기) ──

# AWS
AWS_REGION=ap-northeast-2
S3_BUCKET_RAW=cpet-rag-raw            # 원본 PDF
S3_BUCKET_ARTIFACTS=cpet-rag-artifacts  # parsed md, LanceDB
LANCEDB_URI=s3://cpet-rag-artifacts/lancedb

# LLM / 생성 (Amazon Bedrock)
BEDROCK_MODEL_ID=anthropic.claude-...   # 생성용 Claude
BEDROCK_RERANK_MODEL=cohere.rerank-...   # (선택) Cohere Rerank
# 폴백: ANTHROPIC_API_KEY=

# 임베딩 (Jina-v3)
JINA_API_KEY=                         # API 사용 시
EMBED_MODEL=jinaai/jina-embeddings-v3 # self-host 시
EMBED_DIM=1024                        # MRL 축소 가능(256/512)

# PDF 파싱 폴백 (VLM)
GEMINI_API_KEY=                       # 복잡 표/수식 폴백

# 메타 보강
UNPAYWALL_EMAIL=cte5301@gmail.com
CROSSREF_MAILTO=cte5301@gmail.com

# 서빙
API_PORT=8110
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# 평가
RAGAS_LLM_MODEL=                      # LLM-as-judge
